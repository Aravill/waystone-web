# Waystone Web Application - Environment Variables

# Server Configuration
PORT=8080

# Google OAuth Configuration
# Required for OAuth login functionality
# Get these from: https://console.cloud.google.com
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web Application)
# 4. Add http://localhost:8080/auth/callback to authorized redirect URIs (adjust for production domain)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# OAuth Callback URL
# Should match the redirect URI configured in Google Cloud Console
# For local development: http://localhost:8080/auth/callback
# For production: https://your-domain.com/auth/callback
OAUTH_CALLBACK_URL=http://localhost:8080/auth/callback

# Session Secret
# Used to sign session cookies. Change this to a random string in production.
# Generate a secure value: openssl rand -base64 32
SESSION_SECRET=change-me-to-random-secret-in-production
